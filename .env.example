PORT=3000
NODE_ENV=production

# Upload config
# MAX_FILE_SIZE in bytes (default 10MB = 10485760)
MAX_FILE_SIZE=10485760
# Comma-separated allowed MIME types. Leave empty to allow ALL.
# e.g: image/jpeg,image/png,application/pdf
ALLOWED_TYPES=

# Storage (MinIO)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=
AWS_FORCE_PATH_STYLE=true
AWS_ENDPOINT=http://localhost:9000
AWS_PUBLIC_URL=http://localhost:9000/<bucket>
